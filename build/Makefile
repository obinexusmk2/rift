	$(MAKE) $(MAKESILENT) -f CMakeFiles\rift_shared.dir\build.make CMakeFiles/rift_shared.dir/src/raf/raf.c.obj
.PHONY : src/raf/raf.c.obj

src/raf/raf.i: src/raf/raf.c.i
.PHONY : src/raf/raf.i

# target to preprocess a source file
src/raf/raf.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\rift_static.dir\build.make CMakeFiles/rift_static.dir/src/raf/raf.c.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles\rift_shared.dir\build.make CMakeFiles/rift_shared.dir/src/raf/raf.c.i
.PHONY : src/raf/raf.c.i

src/raf/raf.s: src/raf/raf.c.s
.PHONY : src/raf/raf.s

# target to generate assembly for a file
src/raf/raf.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\rift_static.dir\build.make CMakeFiles/rift_static.dir/src/raf/raf.c.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles\rift_shared.dir\build.make CMakeFiles/rift_shared.dir/src/raf/raf.c.s
.PHONY : src/raf/raf.c.s

